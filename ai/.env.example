# ══════════════════════════════════════════════════
# AI Service Environment Variables
# ══════════════════════════════════════════════════

# ── API ──
AI_API_HOST=0.0.0.0
AI_API_PORT=5001
AI_LOG_LEVEL=INFO

# ── CORS (comma-separated) ──
AI_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173,http://localhost:8080

# ── PostgreSQL (Supabase — for RUL training) ──
POSTGRES_HOST=db.XXXXX.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-db-password

# ── Optional API key (leave empty to disable auth) ──
AI_API_KEY=
