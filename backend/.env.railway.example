# ── Supabase Database ──
SPRING_DATASOURCE_URL=jdbc:postgresql://db.XXXXX.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-supabase-db-password

# ── JWT ──
JWT_SECRET=generate-a-64-char-random-secret-key-here-use-openssl-rand-hex-32

# ── CORS (your Vercel domain) ──
CORS_ALLOWED_ORIGINS=https://synaptiq.vercel.app,http://localhost:5173

# ── AI Service (Railway internal URL) ──
AI_SERVICE_BASE_URL=http://synaptiq-ai.railway.internal:5001

# ── Frontend URL ──
APP_FRONTEND_URL=https://synaptiq.vercel.app

# ── Server ──
SERVER_PORT=8080

# ── Flyway ──
SPRING_FLYWAY_ENABLED=false
