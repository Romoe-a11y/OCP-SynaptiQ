# ══════════════════════════════════════════════════
# Backend Environment Variables
# Copy this file to set env vars on your deployment
# ══════════════════════════════════════════════════

# ── Database (Supabase PostgreSQL) ──
SPRING_DATASOURCE_URL=jdbc:postgresql://db.XXXXX.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-supabase-db-password

# ── JWT ──
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-64-char-random-secret-key

# ── CORS (comma-separated allowed origins) ──
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ── AI Service ──
# On Railway, use internal networking:
AI_SERVICE_BASE_URL=http://synaptiq-ai.railway.internal:5001

# ── Frontend URL (for email links etc.) ──
APP_FRONTEND_URL=https://your-app.vercel.app

# ── Server ──
SERVER_PORT=8080

# ── Flyway ──
# Set to false if using Supabase with manual migrations
SPRING_FLYWAY_ENABLED=true

# ── Email (optional — Resend) ──
RESEND_API_KEY=
RESEND_FROM=
